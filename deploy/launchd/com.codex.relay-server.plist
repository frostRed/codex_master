<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex.relay-server</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>set -a; source /etc/codex-master/relay.env; exec /usr/local/bin/relay_server</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/usr/local/var/codex-master/relay</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>UserName</key>
  <string>codex</string>

  <key>StandardOutPath</key>
  <string>/usr/local/var/log/codex-master/relay-server.log</string>

  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/codex-master/relay-server.log</string>
</dict>
</plist>
