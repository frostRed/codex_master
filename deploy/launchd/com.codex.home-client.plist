<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex.home-client</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>set -a; source /etc/codex-master/home-client.env; exec /usr/local/bin/codex_master</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/REPLACE_ME/Code/codex_master</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/REPLACE_ME/Library/Logs/codex-master/home-client.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/REPLACE_ME/Library/Logs/codex-master/home-client.log</string>
</dict>
</plist>
