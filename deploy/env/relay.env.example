# Codex relay server environment
# Copy to /etc/codex-master/relay.env and replace placeholders.

RELAY_SERVER_BIND=127.0.0.1:8080
RELAY_SERVER_STATE_FILE=/var/lib/codex-master/relay/relay-state.json
RELAY_SERVER_COMPACTION_THRESHOLD=200
RELAY_SERVER_SEGMENT_EVENT_LIMIT=100

# Strict auth defaults (recommended for production)
# Token rotation:
# - keep old+new in RELAY_SERVER_CLIENT_TOKENS during rollout
# - after all clients switch, remove old token
RELAY_SERVER_CLIENT_TOKENS=token-v1,token-v2
# Emergency revoke list (comma separated), checked before allowlist:
RELAY_SERVER_CLIENT_TOKENS_REVOKED=

RELAY_SERVER_BROWSER_AUTH_REQUIRED=true
RELAY_SERVER_BROWSER_AUTH_USER_HEADER=X-Relay-User
RELAY_SERVER_BROWSER_AUTH_PROXY_SECRET_HEADER=X-Relay-Auth-Secret
RELAY_SERVER_BROWSER_AUTH_PROXY_SECRET=replace-with-a-long-random-secret
RELAY_SERVER_BROWSER_ALLOWED_ORIGINS=https://relay.example.com
RELAY_SERVER_BROWSER_ALLOW_ANONYMOUS=false

# Keep false in production. Only for loopback local dev.
RELAY_SERVER_ALLOW_INSECURE_DEV=false
