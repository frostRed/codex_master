# Codex home client environment
# Copy to /etc/codex-master/home-client.env and replace placeholders.

HOME_CLIENT_TRANSPORT=relay
HOME_CLIENT_RELAY_URL=wss://relay.example.com/ws/client
HOME_CLIENT_AUTH_TOKEN=replace-with-same-token-as-relay-client-token
HOME_CLIENT_DEVICE_ID=home-machine-1
HOME_CLIENT_DEVICE_NAME=Home Machine

# Keep false in production. If true, ws:// is only allowed on localhost/127.0.0.1/[::1].
HOME_CLIENT_ALLOW_INSECURE_WS=false

# Reconnect behavior
HOME_CLIENT_RECONNECT_DELAY_SECS=3
HOME_CLIENT_RECONNECT_MAX_DELAY_SECS=60
HOME_CLIENT_RECONNECT_JITTER_MILLIS=750
HOME_CLIENT_RECONNECT_RESET_AFTER_SECS=30

# Workspace allowlist
HOME_CLIENT_WORKSPACES_JSON='[{"id":"default","name":"Default Workspace","path":"/srv/codex/workspaces/default"}]'
HOME_CLIENT_DEFAULT_WORKSPACE_ID=default

# Optional
CODEX_ACP_BIN=codex-acp
