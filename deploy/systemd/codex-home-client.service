[Unit]
Description=Codex Home Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=codex
Group=codex
WorkingDirectory=/srv/codex/workspaces/default
EnvironmentFile=/etc/codex-master/home-client.env
ExecStart=/usr/local/bin/codex_master
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/srv/codex/workspaces /var/log/codex-master
StandardOutput=append:/var/log/codex-master/home-client.log
StandardError=append:/var/log/codex-master/home-client.log

[Install]
WantedBy=multi-user.target
