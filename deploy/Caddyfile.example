{
    email {$ACME_EMAIL}
}

relay.example.com {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
    }

    handle /healthz* {
        reverse_proxy 127.0.0.1:8080
    }

    # Optional defense-in-depth.
    # Relay already enforces its own /login + cookie session auth.
    basic_auth {
        {$RELAY_BASIC_AUTH_USER} {$RELAY_BASIC_AUTH_PASSWORD_HASH}
    }

    reverse_proxy 127.0.0.1:8080
}
